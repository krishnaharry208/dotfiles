[colors]
background = #1a1b26
background-alt = #24283b
foreground = #a9b1d6
primary = #7aa2f7
secondary = #bb9af7
alert = #f7768e
disabled = #565f89
transparent = #00000000

[bar/example]
width = 100%
height = 28pt
radius = 0

; Floating effect
border-size = 4pt
border-color = ${colors.transparent}

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 0
padding-right = 0
module-margin = 1

;font-0 text | font-1 rounded corner | font-2 icons |
font-0 = "JetBrainsMono Nerd Font:style=Bold:size=11;4"
font-1 = "JetBrainsMono Nerd Font:size=24;5"
font-2 = "JetBrainsMono Nerd Font:size=16;4"

modules-left = xworkspaces volume
modules-center = title
modules-right = battery network power

cursor-click = pointer
enable-ipc = true

# --- MODULES ---

[module/xworkspaces]
type = internal/xworkspaces
pin-workspaces = true

; Always show 1 2 3 4 5
icon-0 = 1;1
icon-1 = 2;2
icon-2 = 3;3
icon-3 = 4;4
icon-4 = 5;5

format = <label-state>
format-prefix = "%{T2}%{T-}"
format-prefix-foreground = ${colors.background-alt}
format-suffix = "%{T2}%{T-}"
format-suffix-foreground = ${colors.background-alt}

label-active = %icon%
label-active-background = ${colors.background-alt}
label-active-foreground = ${colors.primary}
label-active-underline = ${colors.primary}
label-active-padding = 1

label-occupied = %icon%
label-occupied-background = ${colors.background-alt}
label-occupied-padding = 1

label-empty = %icon%
label-empty-background = ${colors.background-alt}
label-empty-foreground = ${colors.disabled}
label-empty-padding = 1

[module/title]
type = internal/xwindow
format = <label>
format-prefix = "%{T2}%{T-}"
format-prefix-foreground = ${colors.background-alt}
format-suffix = "%{T2}%{T-}"
format-suffix-foreground = ${colors.background-alt}

label = " %title% "
label-maxlen = 45
label-background = ${colors.background-alt}
label-empty = " Desktop "
label-empty-background = ${colors.background-alt}

[module/volume]
type = custom/script
exec = ~/.config/polybar/volume.sh
interval = 0

click-left = pactl set-sink-mute @DEFAULT_SINK@ toggle
scroll-up = pactl set-sink-volume @DEFAULT_SINK@ +5%
scroll-down = pactl set-sink-volume @DEFAULT_SINK@ -5%


[module/network]
type = internal/network
interface-type = wireless
format-connected = <label-connected>
format-connected-prefix = "%{T2}%{T-}"
format-connected-prefix-foreground = ${colors.background-alt}
format-connected-suffix = "%{T2}%{T-}"
format-connected-suffix-foreground = ${colors.background-alt}
label-connected = "  %essid% "
label-connected-background = ${colors.background-alt}

[module/power]
type = custom/text
format = <label>
format-prefix = "%{T2}%{T-}"
format-prefix-foreground = ${colors.background-alt}
format-suffix = "%{T2}%{T-}"
format-suffix-foreground = ${colors.background-alt}

label = "  "
label-background = ${colors.background-alt}
label-foreground = ${colors.alert}
click-left = ~/.config/polybar/powermenu.sh

[module/battery]
type = internal/battery
full-at = 99
battery = BAT0
adapter = ADP1
poll-interval = 5

; Charging State
format-charging = <label-charging>
format-charging-prefix = "%{T2}%{T-}"
format-charging-prefix-foreground = ${colors.background-alt}
format-charging-suffix = "%{T2}%{T-}"
format-charging-suffix-foreground = ${colors.background-alt}

label-charging = " 󱐋 %percentage%% "
label-charging-background = ${colors.background-alt}
label-charging-foreground = ${colors.primary}

; Discharging State
format-discharging = <label-discharging>
format-discharging-prefix = "%{T2}%{T-}"
format-discharging-prefix-foreground = ${colors.background-alt}
format-discharging-suffix = "%{T2}%{T-}"
format-discharging-suffix-foreground = ${colors.background-alt}

label-discharging = "  %percentage%% "
label-discharging-background = ${colors.background-alt}
label-discharging-foreground = ${colors.foreground}

; Full State
format-full = <label-full>
format-full-prefix = "%{T2}%{T-}"
format-full-prefix-foreground = ${colors.background-alt}
format-full-suffix = "%{T2}%{T-}"
format-full-suffix-foreground = ${colors.background-alt}

label-full = "  Full "
label-full-background = ${colors.background-alt}
label-full-foreground = ${colors.primary}
